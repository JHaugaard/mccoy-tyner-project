# ENVIRONMENT VARIABLES TEMPLATE
# Copy to .env.local and fill in values. Never commit real secrets.

# LLM API Keys
GEMINI_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Project-Specific Keys (add as needed)

# Apple Music / MusicKit  (SERVING PHASE — not needed for data gathering;
# cover art + 30s previews are free via the iTunes Search API, no token.)
# The developer token is a JWT (ES256) signed from your .p8 key, max 180-day exp.
# Team ID — Apple Developer > Membership details (10 chars)
APPLE_MUSIC_TEAM_ID=GL659H3JHY
# MusicKit Key ID — Certificates, Identifiers & Profiles > Keys (10 chars)
APPLE_MUSIC_KEY_ID=
# Absolute path to the AuthKey_XXXXXXXXXX.p8 file. Store it OUTSIDE this repo
# (e.g. ~/.secrets/); it is a private key — never commit it. (*.p8 is gitignored.)
APPLE_MUSIC_PRIVATE_KEY_PATH=
# Storefront for catalog lookups (default: us)
APPLE_MUSIC_STOREFRONT=us
